# Database Configuration
DATABASE_URL="postgresql://astu_user:astu_password@localhost:5432/astu_complaints"
DATABASE_NAME=astu_complaints
DATABASE_USER=astu_user
DATABASE_PASSWORD=astu_password

# Server Configuration
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:8080

# JWT Configuration
JWT_SECRET=astu-super-secret-jwt-key-change-in-production-2024
JWT_EXPIRES_IN=7d

# Google Gemini AI Configuration
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Brevo SMTP Settings
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-email@smtp-brevo.com
SMTP_PASS=your-brevo-smtp-api-key

# Sender Info
EMAIL_FROM=girmasamuel200@gmail.com

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=astu-session-secret-change-in-production

# CORS Configuration
CORS_ORIGIN=http://localhost:8080

