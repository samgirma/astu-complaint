# Database Configuration
DATABASE_NAME=astu_complaints
DATABASE_USER=astu_user
DATABASE_PASSWORD=astu_password_123

# JWT Configuration
JWT_SECRET=astu-super-secret-jwt-key-minimum-32-characters-long
JWT_EXPIRES_IN=7d

# SMTP Configuration (placeholder values)
SMTP_HOST=smtp-relay.brevo.com
SMTP_USER=your-brevo-email@example.com
SMTP_PASS=your-brevo-smtp-api-key
EMAIL_FROM=noreply@astu.edu.et

# Redis Configuration
REDIS_PASSWORD=

# Google Gemini AI Configuration (placeholder)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Cloudinary Configuration (placeholder)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Frontend Configuration
FRONTEND_URL=http://localhost:8080

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security Headers
NODE_ENV=production
